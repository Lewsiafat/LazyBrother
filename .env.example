# =================================
# LazyBrother Configuration
# =================================
# Copy this file to .env and fill in your values

# --- LLM Provider ---
# Options: "openai" | "gemini" | "claude"
LLM_PROVIDER=openai

# --- LLM Model (optional, leave empty for provider default) ---
# OpenAI:  gpt-4o, gpt-4o-mini, gpt-4-turbo, o1, o3-mini
# Gemini:  gemini-2.5-pro, gemini-2.0-flash, gemini-2.5-flash
# Claude:  claude-sonnet-4-20250514, claude-3-5-haiku-20241022
LLM_MODEL=

# --- LLM API Keys ---
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Data Source API Keys ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# --- Server ---
HOST=0.0.0.0
PORT=8000
